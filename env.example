# ---- Telegram ----
# Get this from @BotFather on Telegram after creating your bot
TELEGRAM_BOT_TOKEN=

# ---- WhatsApp Cloud API (Meta) ----
# From your Meta App Dashboard > WhatsApp > API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Any random string you make up - used to verify the webhook with Meta
WHATSAPP_VERIFY_TOKEN=changeme123
# From App Settings > Basic in your Meta App. Enables signature checks on
# incoming webhook requests - set this before exposing the bot publicly.
WHATSAPP_APP_SECRET=

# Local port the WhatsApp webhook server listens on (behind your reverse
# proxy / nginx). install.sh checks this is free and offers an alternative
# if something else is already using it.
WEBHOOK_PORT=8080

# ---- Discord ----
# Create an app + bot at https://discord.com/developers/applications
# Enable "Message Content Intent" under Bot settings, then copy the token here
DISCORD_BOT_TOKEN=

# ---- AI features (optional) ----
# Self-hosted web search - no API key, no quota. Run the bundled
# docker-compose.searxng.yml, then point this at it. Powers: 1) the
# /ask web_lookup tool, 2) tier-4 scraper fallback (find a novel by web
# search when its page is unreachable). Leave blank to fall back to the
# legacy GEMINI_API_KEY/TAVILY_API_KEY path below for those two features.
SEARXNG_URL=

# Legacy fallback for the two features above, only used if SEARXNG_URL
# is blank. Free API key from https://aistudio.google.com/apikey.
# Used for: 1) /ask natural-language command (also the orchestration
# itself if no local Ollama model is set up), 2) last-resort scraper
# fallback when a novel's CSS selector AND the built-in "chapter"
# heuristic both fail (e.g. after a site redesign).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Legacy backup search for tier 4, used if both SearXNG and Gemini are
# unavailable. Free tier: 1,000 searches/month. https://tavily.com
TAVILY_API_KEY=

# ---- Access control ----
# Comma-separated list of Telegram numeric user IDs allowed to use the bot
# (message @userinfobot on Telegram to get your own ID)
ALLOWED_TELEGRAM_IDS=

# Comma-separated list of WhatsApp phone numbers (with country code, no +)
# allowed to use the bot, e.g. 15551234567
ALLOWED_WHATSAPP_NUMBERS=

# Comma-separated list of Discord numeric user IDs allowed to use the bot
# (enable Developer Mode in Discord settings, right-click your name > Copy User ID)
ALLOWED_DISCORD_IDS=

# ---- Scheduler ----
# How often (in minutes) to check for new chapters/episodes
CHECK_INTERVAL_MINUTES=90

# ---- Storage ----
DATABASE_PATH=data/bot.db
